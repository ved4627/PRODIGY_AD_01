<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvDisplay"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="bottom|end"
        android:padding="24dp"
        android:text="0"
        android:textColor="#FFFFFF"
        android:textSize="64sp" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:rowCount="5">

        <Button style="@style/Widget.MaterialComponents.Button.TextButton"
            android:text="AC" android:textColor="#FF9800" android:textSize="24sp"
            android:layout_columnWeight="1" android:onClick="onClearClick"/>
        <Button style="@style/Widget.MaterialComponents.Button.TextButton"
            android:text="+/-" android:textColor="#FF9800" android:textSize="24sp"
            android:layout_columnWeight="1" android:onClick="onOperatorClick"/>
        <Button style="@style/Widget.MaterialComponents.Button.TextButton"
            android:text="%" android:textColor="#FF9800" android:textSize="24sp"
            android:layout_columnWeight="1" android:onClick="onOperatorClick"/>
        <Button style="@style/Widget.MaterialComponents.Button.TextButton"
            android:text="/" android:textColor="#FF9800" android:textSize="24sp"
            android:layout_columnWeight="1" android:onClick="onOperatorClick"/>

        <Button style="@style/Widget.MaterialComponents.Button.TextButton"
            android:text="7" android:textColor="#FFFFFF" android:textSize="24sp"
            android:layout_columnWeight="1" android:onClick="onNumberClick"/>
        <Button style="@style/Widget.MaterialComponents.Button.TextButton"
            android:text="8" android:textColor="#FFFFFF" android:textSize="24sp"
            android:layout_columnWeight="1" android:onClick="onNumberClick"/>
        <Button style="@style/Widget.MaterialComponents.Button.TextButton"
            android:text="9" android:textColor="#FFFFFF" android:textSize="24sp"
            android:layout_columnWeight="1" android:onClick="onNumberClick"/>
        <Button style="@style/Widget.MaterialComponents.Button.TextButton"
            android:text="*" android:textColor="#FF9800" android:textSize="24sp"
            android:layout_columnWeight="1" android:onClick="onOperatorClick"/>

        <Button style="@style/Widget.MaterialComponents.Button.TextButton"
            android:text="4" android:textColor="#FFFFFF" android:textSize="24sp"
            android:layout_columnWeight="1" android:onClick="onNumberClick"/>
        <Button style="@style/Widget.MaterialComponents.Button.TextButton"
            android:text="5" android:textColor="#FFFFFF" android:textSize="24sp"
            android:layout_columnWeight="1" android:onClick="onNumberClick"/>
        <Button style="@style/Widget.MaterialComponents.Button.TextButton"
            android:text="6" android:textColor="#FFFFFF" android:textSize="24sp"
            android:layout_columnWeight="1" android:onClick="onNumberClick"/>
        <Button style="@style/Widget.MaterialComponents.Button.TextButton"
            android:text="-" android:textColor="#FF9800" android:textSize="24sp"
            android:layout_columnWeight="1" android:onClick="onOperatorClick"/>

        <Button style="@style/Widget.MaterialComponents.Button.TextButton"
            android:text="1" android:textColor="#FFFFFF" android:textSize="24sp"
            android:layout_columnWeight="1" android:onClick="onNumberClick"/>
        <Button style="@style/Widget.MaterialComponents.Button.TextButton"
            android:text="2" android:textColor="#FFFFFF" android:textSize="24sp"
            android:layout_columnWeight="1" android:onClick="onNumberClick"/>
        <Button style="@style/Widget.MaterialComponents.Button.TextButton"
            android:text="3" android:textColor="#FFFFFF" android:textSize="24sp"
            android:layout_columnWeight="1" android:onClick="onNumberClick"/>
        <Button style="@style/Widget.MaterialComponents.Button.TextButton"
            android:text="+" android:textColor="#FF9800" android:textSize="24sp"
            android:layout_columnWeight="1" android:onClick="onOperatorClick"/>

        <Button style="@style/Widget.MaterialComponents.Button.TextButton"
            android:text="0" android:textColor="#FFFFFF" android:textSize="24sp"
            android:layout_columnSpan="2" android:layout_columnWeight="2" android:onClick="onNumberClick"/>
        <Button style="@style/Widget.MaterialComponents.Button.TextButton"
            android:text="." android:textColor="#FFFFFF" android:textSize="24sp"
            android:layout_columnWeight="1" android:onClick="onNumberClick"/>
        <Button style="@style/Widget.MaterialComponents.Button.TextButton"
            android:text="=" android:textColor="#FFFFFF" android:backgroundTint="#FF9800"
            android:textSize="24sp" android:layout_columnWeight="1" android:onClick="onEqualClick"/>

    </GridLayout>

</LinearLayout>